cd templates
cat > feed.html << 'FIM'
<!DOCTYPE html>
<html>
<head>
    <title>ÔIO - Feed</title>
    <style>
        body { background: #009739; font-family: Arial; margin: 0; padding: 20px; }
        .header { background: #FEDD00; padding: 15px; text-align: center; font-size: 24px; font-weight: bold; border-bottom: 3px solid #009739; }
        .container { max-width: 600px; margin: auto; background: white; padding: 20px; border-radius: 10px; margin-top: 20px; }
        textarea { width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #ccc; }
        button { background: #FEDD00; color: black; font-weight: bold; padding: 10px; border: none; border-radius: 5px; cursor: pointer; width: 100%; margin-top: 10px; }
        .post { border-bottom: 1px solid #ddd; padding: 10px 0; }
        .data { font-size: 12px; color: gray; }
        a { color: #009739; text-decoration: none; margin: 0 10px; }
        .nav { text-align: center; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="header">
        🟢 ÔIO 🟡
    </div>
    <div class="nav">
        <a href="/perfil/{{ session['usuario_id'] }}">👤 Meu Perfil</a> |
        <a href="/feed">🏠 Feed</a> |
        <a href="/sair">🚪 Sair</a>
    </div>
    <div class="container">
        <h3>Olá, {{ session['usuario_nome'] }}!</h3>
        <form method="POST" action="/postar">
            <textarea name="conteudo" placeholder="O que você está pensando?" required></textarea>
            <button type="submit">Publicar</button>
        </form>
    </div>
    <div class="container">
        <h3>Feed de Notícias</h3>
        {% for post in posts %}
            <div class="post">
                <p>{{ post.conteudo }}</p>
                <div class="data">{{ post.data_criacao.strftime('%d/%m/%Y %H:%M') }}</div>
            </div>
        {% endfor %}
    </div>
</body>
</html>
FIM
